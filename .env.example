# Kaggle API credentials (for historical match data)
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# football-data.org API key (primary WC2026 fixture source)
FOOTBALL_DATA_API_KEY=your_football_data_api_key

# API-Football (api-sports.io) key (fallback fixture source)
API_FOOTBALL_KEY=your_api_football_key

# Primary fixture source: "football_data" | "api_football" | "wikipedia"
PRIMARY_FIXTURE_SOURCE=football_data

# Enable xG data fetching (Phase 2 only, requires soccerdata)
ENABLE_XG=false

# Bayesian model settings
MCMC_DRAWS=1000
MCMC_TUNE=500
MCMC_CHAINS=2

# Simulation settings
MONTE_CARLO_ITERATIONS=10000

# Logging
LOG_LEVEL=INFO
